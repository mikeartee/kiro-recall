{
  "name": "kiro-recall: S3 Sync",
  "version": "1.1.0",
  "description": "Disabled — S3 sync target (Ami) no longer exists. Re-enable and update sync-config.json with a valid bucket when needed.",
  "when": {
    "type": "agentStop"
  },
  "then": {
    "type": "runCommand",
    "command": "powershell -ExecutionPolicy Bypass -File \"C:\\Dev\\kiro-recall\\sync\\s3-sync.ps1\"",
    "timeout": 60
  },
  "disabled": true
}
